# Database
DATABASE_URL=file:./data/archiver.db

# Redis
REDIS_URL=redis://localhost:6379

# Downloads
SHARE_LOCATION=./downloads
MAX_CONCURRENT_DOWNLOADS=10

# Notifications (optional)
NTFY_URL=

# Kavita Integration (optional)
KAVITA_BASE_URL=
KAVITA_API_KEY=
KAVITA_PLUGIN_NAME=Downloader
KAVITA_LIBRARY_ID=
KAVITA_FORCE_SCAN=false
KAVITA_SCAN_DELAY_MS=15000
