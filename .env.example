# Database
DATABASE_URL=file:./data/archiver.db

# Downloads
DOWNLOAD_LOCATION=./downloads
MAX_CONCURRENT_DOWNLOADS=10

# Plugins
PLUGINS_DIR=./plugins

# Notifications (optional)
NTFY_URL=

# Community Plugins (optional — override the default community plugin manifest URL)
# COMMUNITY_PLUGINS_URL=https://example.com/plugins.json

# Umami analytics (optional — omit to disable client-side tracking)
# For Docker, set before build: docker compose build --build-arg NEXT_PUBLIC_UMAMI_WEBSITE_ID=...
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Optional — self-hosted script URL (defaults to Umami Cloud)
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
